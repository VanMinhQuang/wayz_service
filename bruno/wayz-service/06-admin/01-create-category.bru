meta {
  name: Create category (admin)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/admin/categories
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  content-type: application/json
}

body:json {
  {
    "name": "Bruno test category",
    "icon": "coffee"
  }
}
