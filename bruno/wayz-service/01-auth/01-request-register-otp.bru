meta {
  name: Request register OTP
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/otp
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "phone": "{{phone}}",
    "purpose": "register"
  }
}

tests {
  test("OTP request succeeds", function() {
    expect(res.status).to.equal(201);
  });
}
